{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build active file",
            "command": "/usr/bin/g++", // 윈도우라면 "g++.exe" 등으로 경로 수정 필요
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++17", // C++17 사용
                "-g",
                "${file}", // 현재 열린 소스 파일
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}" // 소스 파일과 같은 폴더에 실행 파일 생성
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "default": true
            },
            "detail": "컴파일러: /usr/bin/g++"
        }
    ]
}